# ConvertEase — Environment Variables
#
# Copy this file to `.env` and fill in your values.
# Only variables prefixed with VITE_ are exposed to the frontend bundle.
# Never put secrets (API keys, tokens, database URLs) in VITE_* variables.

# ─── Ad Provider Configuration ───────────────────────────────────────
# Accepted values: "mock" | "adsense" | "custom"
VITE_BANNER_PROVIDER=mock
VITE_REWARDED_PROVIDER=mock
VITE_SPONSORED_PROVIDER=mock
